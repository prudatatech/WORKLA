PORT=8000

# ── Supabase Admin Connection ──
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Redis Server ──
# Local dev: redis://localhost:6380
# Production: Your actual Redis URL
REDIS_URL=redis://localhost:6380

# ── Kafka Broker ──
# Local dev: localhost:9093 (because 9092 is mapped internally to the docker network)
# Production: kafka:9092 (if inside same docker net) or actual Confluent URL
KAFKA_BROKERS=localhost:9093

# ── Observability ──
SENTRY_DSN=

# ── Elasticsearch Server ──
# Local dev: http://localhost:9200
ELASTIC_URL=http://localhost:9200

# ── JWT Authentication ──
# This must perfectly match the JWT secret in your Supabase project settings
JWT_SECRET=YOUR_SUPABASE_JWT_SECRET
