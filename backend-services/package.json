{
  "name": "backend-services",
  "version": "1.0.0",
  "description": "Workla Microservices API Gateway",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "docker:up": "docker-compose up --build -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f backend-app",
    "infra:up": "docker-compose up -d redis elasticsearch kafka",
    "infra:down": "docker-compose down",
    "start:local": "npm run infra:up && npm run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@fastify/caching": "^9.0.3",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/http-proxy": "^11.4.2",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/type-provider-json-schema-to-ts": "^5.0.0",
    "@sentry/node": "^10.43.0",
    "@sentry/profiling-node": "^10.43.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.49.0",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^6.1.0",
    "fastify": "^5.8.2",
    "ioredis": "^5.4.1",
    "json-schema-to-ts": "^3.1.1",
    "jsonwebtoken": "^9.0.2",
    "node-cache": "^5.1.2",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "uuid": "^11.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.13.7",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "eslint": "^9.39.4",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
