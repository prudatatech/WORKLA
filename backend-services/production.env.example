# ────────────────────────────────────────────────────────
# 🚀 WORKLA HYPER-SCALE PRODUCTION ENVIRONMENT VARIABLES
# ────────────────────────────────────────────────────────
# Use this template when deploying to Render, Railway, AWS ECS, etc.

# 1. Server Configuration
# Render automatically assigns PORT. Usually 8000.
PORT=8000
NODE_ENV=production
# Add the URL where your front-ends live so CORS doesn't block them.
CORS_ORIGINS=https://admin.workla.com,https://app.workla.com

# 2. Supabase (Managed Postgres & Auth)
SUPABASE_URL=https://svfmgmvrariwyyxohuvh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# 3. JWT Secret (Must exactly match your Supabase JWT Secret)
# Get from Supabase Dashboard -> Project Settings -> API -> JWT Secret
JWT_SECRET=your_production_jwt_secret

# 4. Upstash Redis (Cache, Socket.io, and Streams)
# Get from Upstash Console -> Redis Cluster -> REST/Node.js copied URL
REDIS_URL=rediss://default:your-upstash-redis-password@your-upstash-endpoint.upstash.io:32549

# 6. Elasticsearch (Managed Search)
# Get from Bonsai or Elastic Cloud deployments
ELASTIC_URL=https://your-elastic-deployment-id.es.us-east-1.aws.elastic-cloud.com:9243

# 7. Razorpay Production Keys
RAZORPAY_KEY_ID=rzp_live_your_live_key
RAZORPAY_KEY_SECRET=your_live_secret
RAZORPAY_WEBHOOK_SECRET=your_strong_webhook_secret

# 8. Sentry Error Tracking (APM)
SENTRY_DSN=https://your-sentry-dsn@o0000.ingest.sentry.io/0000

# 9. Performance Tuning
# Adjust based on Render/AWS memory limits
BODY_LIMIT=10485760 # 10MB
DB_QUERY_TIMEOUT_MS=10000
ELASTIC_TIMEOUT_MS=5000
REDIS_TIMEOUT_MS=5000
SERVER_TIMEOUT_MS=60000
